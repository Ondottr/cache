{
    "name": "nations-original/php-sf-cache",
    "description": "PSR-16 cache adapters (Redis, Memcached, APCu) with helper functions. Works with Symfony, custom frameworks, and legacy projects.",
    "type": "library",
    "license": "ISC",
    "homepage": "https://github.com/Ondottr/cache",
    "authors": [
        {
            "name": "Dmytro Dyvulskyi",
            "email": "eklerk397@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/simple-cache": "^3.0",
        "predis/predis": "^2.0",
        "symfony/filesystem": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "roave/security-advisories": "dev-latest",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "suggest": {
        "ext-apcu": "Required to use APCuCacheAdapter",
        "ext-memcached": "Required to use MemcachedCacheAdapter",
        "symfony/cache": "Allows wrapping these adapters via Symfony\\Component\\Cache\\Psr16Cache",
        "laravel/framework": "^10.0|^11.0 — enables CacheServiceProvider auto-discovery"
    },

    "autoload": {
        "psr-4": {
            "PHP_SF\\Cache\\": "src/"
        },
        "files": [
            "functions/cache_functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PHP_SF\\Cache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "cs:fix": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "PHP_SF\\Cache\\Laravel\\CacheServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-master": "1.0-dev"
        }
    }
}
